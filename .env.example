# git-mcp-server environment variables
# Copy to private/.env and fill in values

# Server
GIT_MCP_HOST=0.0.0.0
GIT_MCP_PORT=8078
GIT_MCP_MCP_TRANSPORT=stdio

# Auth
GIT_MCP_AUTH_MODE=api_key
API_KEY=change_me

# Secret-backed configuration is disabled by default.
# Provide deployment secrets through your runtime environment or an
# operator-managed env file passed to server_control.sh.

# Database (optional, for profile/audit persistence)
# DB_URL=sqlite:///data/git_mcp.db

# Audit
AUDIT_LOG_PATH=./data/audit/audit.jsonl

# Workspace
WORKSPACE_BASE_DIR=./data/workspaces
WORKSPACE_DEFAULT_TTL_SECONDS=3600
