# git-mcp-server — Docker Environment (PS-91)
# Copy to .env and fill in secrets before running.

# ── Server Ports ─────────────────────────────────────────────────
CLOUD_DOG__GIT__API_SERVER__PORT=8585
CLOUD_DOG__GIT__API_SERVER__HOST=0.0.0.0
CLOUD_DOG__GIT__MCP_SERVER__PORT=8586
CLOUD_DOG__GIT__MCP_SERVER__HOST=0.0.0.0
CLOUD_DOG__SERVER__PORT=8585
CLOUD_DOG__SERVER__HOST=0.0.0.0
CLOUD_DOG__SERVER__MCP__PORT=8586

# ── Authentication ───────────────────────────────────────────────
# API key for tool execution (from Vault: vault.dev.keys.api_key)
CLOUD_DOG__GIT__API_KEY=
JWT_ISSUER=cloud-dog-local
JWT_AUDIENCE=cloud-dog-services
JWT_JWKS_URL=https://git.cloud-dog.net
GIT_MCP_SEED_KEY_FILE=/app/data/seed_api_key.txt

# ── Git Configuration ────────────────────────────────────────────
CLOUD_DOG__GIT__WORKSPACE_ROOT=/app/data/workspaces
CLOUD_DOG__GIT__DEFAULT_REMOTE=https://git.cloud-dog.net

# ── Vault (optional — for credential resolution) ────────────────
VAULT_ADDR=https://vault0.cloud-dog.net
VAULT_TOKEN=
CLOUD_DOG__VAULT__MOUNT_POINT=cloud_dog_ai
CLOUD_DOG__VAULT__CONFIG_PATH=config

# ── Corporate Proxy (recommended in Cloud-Dog networks) ─────────
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost,.cloud-dog.net

# ── Logging ──────────────────────────────────────────────────────
CLOUD_DOG__GIT__LOG__LEVEL=INFO
CLOUD_DOG__GIT__AUDIT__ENABLED=true

# ── TLS (optional) ──────────────────────────────────────────────
# Single combined bundle:
# CLOUD_DOG_TLS_CA_BUNDLE=/app/certs/ca-bundle.crt
# Or provide both chains separately:
# CLOUD_DOG_TLS_CORPORATE_CA=/app/certs/corporate-internal.crt
# CLOUD_DOG_TLS_ACME_CA=/app/certs/acme-chain.crt
